<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ferry.ViewModels"
        xmlns:views="using:Ferry.Views"
        x:Class="Ferry.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Ferry"
        Width="500"
        Height="700"
        MinWidth="400"
        MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <TabControl Margin="8">
        <!-- 転送タブ -->
        <TabItem Header="転送">
            <DockPanel Margin="8">
                <!-- 接続パネル（上部） -->
                <views:ConnectionPanel x:Name="ConnectionArea"
                                       DockPanel.Dock="Top"
                                       DataContext="{Binding Connection}"
                                       Margin="0,0,0,16" />

                <!-- 転送パネル（QR コード表示中は非表示） -->
                <views:TransferPanel DataContext="{Binding Transfer}"
                                     IsVisible="{Binding #ConnectionArea.((vm:ConnectionViewModel)DataContext).QrCodeImage, Converter={x:Static ObjectConverters.IsNull}}" />
            </DockPanel>
        </TabItem>

        <!-- 設定タブ -->
        <TabItem Header="設定">
            <ScrollViewer Margin="8">
                <views:SettingsPanel DataContext="{Binding Settings}" />
            </ScrollViewer>
        </TabItem>
    </TabControl>

</Window>
