#!/bin/sh

set -e

case "$1" in
    remove|upgrade|deconfigure)
        if pgrep -f '/opt/ferry/ferry' > /dev/null; then
            echo "Stopping running Ferry instance..."
            pkill -f '/opt/ferry/ferry' || true
            sleep 1
        fi
    ;;

    failed-upgrade)
    ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0
